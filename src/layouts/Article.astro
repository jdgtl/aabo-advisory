---
import Base from "./Base.astro";
import Nav from "@/components/sections/Nav.astro";
import Footer from "@/components/sections/Footer.astro";
import RevealWrapper from "@/components/ui/RevealWrapper";
import { articleJsonLd, breadcrumbJsonLd } from "@/lib/jsonld";
import ArticleActions from "@/components/interactive/ArticleActions";

interface Props {
  title: string;
  category: string;
  excerpt: string;
  keyTakeaway?: string;
  date: string;
  readTime: string;
  docId: string;
  slug: string;
  otherArticles: {
    slug: string;
    title: string;
    category: string;
  }[];
}

const { title, category, excerpt, keyTakeaway, date, readTime, docId, slug, otherArticles } = Astro.props;

const jsonld = [
  articleJsonLd({
    headline: title,
    description: excerpt,
    datePublished: date,
    slug,
    articleSection: category,
    readTime,
  }),
  breadcrumbJsonLd([
    { name: "Home", url: "https://aaboadvisory.com" },
    { name: "Insights", url: "https://aaboadvisory.com/insights" },
    { name: title },
  ]),
];
---

<Base title={`${title} — AABO Advisory`} description={excerpt} jsonld={jsonld}>
  <Nav light />

  {/* Classification bar */}
  <div class="bg-primary border-b border-accent/[0.15] px-6 sm:px-10 md:px-16 lg:px-20">
    <div class="max-w-[1100px] mx-auto flex items-center gap-5 h-11">
      <div class="px-2.5 py-0.5 border border-accent text-[9px] tracking-[0.15em] uppercase text-accent font-semibold">
        {category}
      </div>
      <div class="w-px h-4 bg-accent/25"></div>
      <div class="text-[10px] text-warm/60">{docId}</div>
      <div class="flex-1"></div>
      <div class="text-[10px] text-warm/40">{date} &middot; {readTime}</div>
      <div class="w-px h-4 bg-accent/25 print-hide"></div>
      <button onclick="window.print()" class="print-hide text-[10px] text-warm/40 hover:text-accent transition-colors cursor-pointer tracking-[0.05em] uppercase">Print</button>
    </div>
  </div>

  {/* Print-only header — visible only when printing */}
  <div class="print-header">
    <img src="/logo.svg" alt="AABO Advisory" class="print-logo" />
    <div class="print-meta">
      <span class="print-category">{category}</span>
      <span class="print-separator">&middot;</span>
      <span>{date}</span>
      <span class="print-separator">&middot;</span>
      <span>{readTime}</span>
    </div>
    <hr class="print-rule" />
  </div>

  <article id="main-content" class="bg-canvas">
    {/* Article header */}
    <div class="border-b border-mid px-6 md:px-12 lg:px-20 py-12 lg:pt-16 lg:pb-12">
      <div class="max-w-[1100px] mx-auto">
        <RevealWrapper client:visible>
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10 lg:gap-20 items-end">
            <div>
              <h1 class="font-heading text-[28px] sm:text-[36px] lg:text-[44px] font-bold text-primary leading-[1.15] mb-5">
                {title}
              </h1>
              <p class="text-base lg:text-[17px] leading-[1.7] text-text/65 max-w-[560px]">
                {excerpt}
              </p>
            </div>
            <div class="bg-light p-5 border-l-[3px] border-accent">
              <div class="text-[10px] tracking-[0.15em] uppercase text-accent mb-3 font-semibold">
                Document Summary
              </div>
              {[
                { l: "Type", v: category },
                { l: "Published", v: date },
                { l: "Reading Time", v: readTime },
                { l: "Classification", v: "Advisory" },
              ].map((r) => (
                <div class="flex justify-between py-1.5 border-b border-mid text-xs">
                  <span class="text-text/45">{r.l}</span>
                  <span class="text-primary font-semibold">{r.v}</span>
                </div>
              ))}
            </div>
          </div>
        </RevealWrapper>
      </div>
    </div>

    {/* Article body + sidebar */}
    <div class="px-6 md:px-12 lg:px-20 py-14 lg:pb-24">
      <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10 lg:gap-20 items-start">
        <div class="article-body">
          <slot />
        </div>

        {/* Sidebar */}
        <aside class="lg:sticky lg:top-[120px]">
          <RevealWrapper client:visible delay={0.2}>
            <div class="mb-10">
              <div class="text-[10px] tracking-[0.15em] uppercase text-accent mb-4 font-semibold">
                Key Takeaway
              </div>
              <div class="border-l-2 border-accent pl-5">
                <p class="font-heading text-base leading-[1.6] text-primary italic">
                  {keyTakeaway || excerpt}
                </p>
              </div>
            </div>
          </RevealWrapper>

          <RevealWrapper client:visible delay={0.3}>
            <nav aria-label="Related articles" class="bg-primary p-6">
              <div class="text-[10px] tracking-[0.15em] uppercase text-accent mb-4 font-semibold">
                Continue Reading
              </div>
              {otherArticles.map((other) => (
                <a
                  href={`/insights/${other.slug}`}
                  class="block py-3 border-t border-canvas/[0.06] no-underline transition-opacity hover:opacity-70"
                >
                  <div class="text-[9px] text-accent tracking-[0.1em] uppercase mb-1">
                    {other.category}
                  </div>
                  <div class="text-[13px] text-canvas leading-[1.4] font-medium">
                    {other.title}
                  </div>
                </a>
              ))}
            </nav>
          </RevealWrapper>

          <RevealWrapper client:visible delay={0.4}>
            <div class="mt-6 bg-primary p-6 print-hide">
              <div class="text-[10px] tracking-[0.15em] uppercase text-accent mb-2 font-semibold">
                Actions
              </div>
              <ArticleActions title={title} client:visible />
            </div>
          </RevealWrapper>
        </aside>
      </div>
    </div>
  </article>

  <Footer />
</Base>

<style is:global>
  .article-body p:first-of-type::first-letter {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 3rem;
    float: left;
    line-height: 0.8;
    margin-right: 0.75rem;
    margin-top: 0.25rem;
    color: var(--color-accent, #B8965A);
  }

  .article-body p:first-of-type {
    font-size: 1.0625rem;
    line-height: 1.9;
    color: var(--color-text, #1A1A1A);
    opacity: 0.85;
    margin-bottom: 1.75rem;
  }

  .article-body p {
    font-size: 1rem;
    line-height: 1.9;
    color: var(--color-text, #1A1A1A);
    opacity: 0.78;
    margin-bottom: 1.5rem;
  }

  .article-body h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary, #0F1B2D);
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
  }

  .article-body h3 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary, #0F1B2D);
    margin: 2rem 0 0.75rem;
    line-height: 1.3;
  }

  .article-body blockquote {
    border-left: 2px solid var(--color-accent, #B8965A);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-primary, #0F1B2D);
  }

  .article-body ul {
    margin: 1rem 0 1.5rem;
    padding-left: 1.5rem;
    list-style-type: disc;
  }

  .article-body ol {
    margin: 1rem 0 1.5rem;
    padding-left: 1.5rem;
    list-style-type: decimal;
  }

  .article-body li {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text, #1A1A1A);
    opacity: 0.78;
    margin-bottom: 0.5rem;
  }

  /* Print header — hidden on screen */
  .print-header {
    display: none;
  }

  @media print {
    /* Hide non-content elements */
    nav,
    footer,
    aside,
    .print-hide,
    [data-reveal] {
      display: none !important;
    }

    /* Hide the classification bar and the entire nav/footer components */
    .bg-primary.border-b {
      display: none !important;
    }

    /* Show print header */
    .print-header {
      display: block;
      padding: 1.5rem 2rem 0;
    }

    .print-logo {
      height: 28px;
      margin-bottom: 0.75rem;
    }

    .print-meta {
      font-size: 10px;
      color: #666;
      letter-spacing: 0.05em;
      margin-bottom: 0.75rem;
    }

    .print-category {
      text-transform: uppercase;
      font-weight: 600;
      color: #B8965A;
      letter-spacing: 0.12em;
      font-size: 9px;
      border: 1px solid #B8965A;
      padding: 1px 6px;
      margin-right: 4px;
    }

    .print-separator {
      margin: 0 0.35em;
      color: #aaa;
    }

    .print-rule {
      border: none;
      border-top: 1px solid #ddd;
      margin: 0;
    }

    /* Layout: single column, full width */
    body {
      background: white !important;
      color: #1A1A1A !important;
    }

    #main-content {
      background: white !important;
    }

    /* Force single-column layout */
    .grid {
      display: block !important;
    }

    /* Hide the sidebar summary card */
    .bg-light.p-5.border-l-\[3px\] {
      display: none !important;
    }

    /* Article body print styles */
    .article-body h2 {
      color: #B8965A !important;
    }

    .article-body p:first-of-type::first-letter {
      color: #B8965A !important;
    }

    /* Clean up spacing */
    .article-body {
      max-width: 100% !important;
    }

    /* Remove animations/transitions */
    * {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
    }

    /* Ensure RevealWrapper contents are visible */
    [class*="RevealWrapper"],
    [class*="reveal"] {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
