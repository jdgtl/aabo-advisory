---
const navLinks = [
  { href: "#approach", label: "Approach" },
  { href: "#services", label: "Advisory" },
  { href: "#insights", label: "Insights" },
  { href: "#about", label: "About" },
];

const year = new Date().getFullYear();
---

<footer class="bg-primary border-t border-canvas/[0.03]">
  <div class="max-w-[1100px] mx-auto grid grid-cols-1 md:grid-cols-[1fr_auto_auto] gap-10 md:gap-[60px] items-start px-6 md:px-12 lg:px-20 pt-12 pb-10">
    {/* Brand */}
    <div>
      <div class="flex items-baseline gap-2 mb-3">
        <span class="font-heading text-base font-bold text-canvas tracking-[0.08em]">AABO</span>
        <span class="text-[10px] tracking-[0.12em] uppercase text-accent">Advisory</span>
      </div>
      <p class="text-xs text-warm/35 leading-relaxed max-w-[280px]">
        Sovereign-grade real estate advisory for diplomatic missions in global capitals.
      </p>
    </div>

    {/* Navigate */}
    <div>
      <div class="text-[10px] tracking-[0.15em] uppercase text-accent mb-3.5 font-semibold">Navigate</div>
      <div class="flex flex-col gap-2.5">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-[13px] text-canvas/50 font-body transition-colors hover:text-accent"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    {/* Connect */}
    <div>
      <div class="text-[10px] tracking-[0.15em] uppercase text-accent mb-3.5 font-semibold">Connect</div>
      <div class="flex flex-col gap-2.5">
        <a href="#contact" class="text-[13px] text-canvas/50 font-body transition-colors hover:text-accent">
          Schedule a Consultation
        </a>
        <span class="text-[13px] text-canvas/50">New York, NY</span>
      </div>
    </div>
  </div>

  {/* Bottom bar */}
  <div class="max-w-[1100px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-2 pt-5 pb-10 border-t border-canvas/[0.03]">
      <div class="text-[11px] text-warm/25">&copy; {year} Aabo Advisory</div>
      <div class="text-[11px] text-warm/25">Discretion &middot; Precision &middot; Stewardship</div>
    </div>
  </div>
</footer>
