---
interface Props {
  headline: string;
  body: string;
  index?: number;
}

const { headline, body, index = 0 } = Astro.props;
const counter = String(index + 1).padStart(2, "0");
---

<article
  class="py-10 lg:py-14 first:pt-0"
  data-advisory-service-box
>
  <div class="text-accent text-[11px] tracking-[0.28em] uppercase font-medium tabular-nums mb-5">
    {counter}
  </div>
  <h3 class="font-heading text-[22px] lg:text-[28px] font-bold text-primary leading-[1.2] mb-5 max-w-[820px]">
    {headline}
  </h3>
  <p class="text-[15px] lg:text-[17px] leading-[1.75] text-text/75 max-w-[780px]">
    {body}
  </p>
</article>
