---
import type { PillarId } from "@/lib/analytics";

interface Props {
  pillarSlug: PillarId;
}

const { pillarSlug } = Astro.props;
---

<div
  class="heartbeat-wrap absolute left-0 right-0 pointer-events-none z-[5]"
  style="bottom: -40px; height: 80px;"
  data-heartbeat
  data-pillar={pillarSlug}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 1200 80"
    preserveAspectRatio="none"
    class="w-full h-full block"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      class="heartbeat-path"
      pathLength="100"
      d="M 0 40 L 700 40 L 716 38 L 722 40 L 732 45 L 738 4 L 744 76 L 750 40 L 756 38 L 762 40 L 1200 40"
      stroke="var(--color-accent-light)"
      stroke-opacity="0.5"
      stroke-width="1"
      fill="none"
      stroke-linejoin="round"
      stroke-linecap="round"
    />
  </svg>
</div>

<style>
  .heartbeat-path {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .heartbeat-wrap.is-visible .heartbeat-path {
    transition: stroke-dashoffset 3s cubic-bezier(0.4, 0, 0.2, 1);
    stroke-dashoffset: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .heartbeat-path {
      stroke-dashoffset: 0;
      transition: none;
    }
  }
</style>

<script>
  import { trackAdvisoryHeartbeatViewed, type PillarId } from "@/lib/analytics";

  function initHeartbeat() {
    const wraps = document.querySelectorAll<HTMLElement>("[data-heartbeat]");
    wraps.forEach((wrap) => {
      if (wrap.dataset.wired === "1") return;
      wrap.dataset.wired = "1";
      const pillar = wrap.dataset.pillar as PillarId;

      // Kick off the animation on the next frame so the initial
      // stroke-dashoffset state is committed before the transition.
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          wrap.classList.add("is-visible");
          trackAdvisoryHeartbeatViewed(pillar);
        });
      });
    });
  }

  initHeartbeat();
  document.addEventListener("astro:page-load", initHeartbeat);
</script>
