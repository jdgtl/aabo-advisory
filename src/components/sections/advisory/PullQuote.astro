---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="py-14 lg:py-20">
  <div class="relative max-w-[720px]">
    <span
      aria-hidden="true"
      role="presentation"
      class="pointer-events-none select-none absolute -top-14 lg:-top-20 left-0 font-heading font-bold leading-none text-primary/[0.07] z-0"
      style="font-size: clamp(90px, 13vw, 150px);"
    >
      &ldquo;
    </span>
    <blockquote
      class="relative z-[1] pl-12 sm:pl-16 font-heading italic text-[16px] sm:text-[18px] lg:text-[20px] leading-[1.6] text-primary"
    >
      {text}
    </blockquote>
  </div>
</div>
