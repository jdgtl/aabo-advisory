---
import Label from "@/components/ui/Label.astro";
import RevealWrapper from "@/components/ui/RevealWrapper";
import { getHomepage } from "@/lib/content";
import { renderLinks } from "@/lib/markdown-links";

const hp = await getHomepage();
const about = hp?.about;

const headline = about?.headline ?? "Confidence in Complexity";
const paragraphs = about?.paragraphs ?? [
  "Our advisory practice grew out of years working with diplomatic missions, international organizations, and global clients navigating New York's real estate market.",
  "We combine market expertise with an understanding of diplomatic process, institutional decision-making, and long-term stewardship — helping missions operate with confidence in one of the world's most complex cities.",
];
---

<section id="about" class="bg-light px-6 py-16 sm:px-10 md:px-16 lg:px-20 lg:py-[100px]">
  <div class="max-w-[1100px] mx-auto">
    <div class="max-w-[680px]">
      <RevealWrapper client:visible>
        <Label text="About" />
      </RevealWrapper>

      <RevealWrapper client:visible delay={0.1}>
        <h2 class="font-heading text-[28px] sm:text-[32px] lg:text-[36px] font-bold text-primary mb-7">
          {headline}
        </h2>
      </RevealWrapper>

      {paragraphs.map((para, i) => (
        <RevealWrapper client:visible delay={0.15 + 0.05 * i}>
          <p class:list={[
            "text-sm lg:text-base leading-[1.85] text-text/80",
            i < paragraphs.length - 1 ? "mb-5" : "",
          ]}>
            <Fragment set:html={renderLinks(para)} />
          </p>
        </RevealWrapper>
      ))}
    </div>
  </div>
</section>
