---
import Label from "@/components/ui/Label.astro";
import RevealWrapper from "@/components/ui/RevealWrapper";
import { renderLinks } from "@/lib/markdown-links";

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  label?: string;
  headline?: string;
  faqs: readonly FAQItem[];
}

const { label = "Frequently Asked Questions", headline = "Common Questions", faqs } = Astro.props;
---

<section class="bg-canvas px-6 py-16 sm:px-10 md:px-16 lg:px-20 lg:py-[80px]">
  <div class="max-w-[1100px] mx-auto">
    <RevealWrapper client:visible>
      <Label text={label} />
    </RevealWrapper>

    <RevealWrapper client:visible delay={0.1}>
      <h2 class="font-heading text-[28px] sm:text-[32px] lg:text-[36px] font-bold text-primary mb-10">
        {headline}
      </h2>
    </RevealWrapper>

    <div class="max-w-[760px] flex flex-col gap-0" data-faq-accordion>
      {faqs.map((faq, i) => (
        <RevealWrapper client:visible delay={0.05 * i}>
          <div class="border-t border-mid last:border-b" data-faq-item>
            <button
              type="button"
              class="w-full flex items-center justify-between gap-4 py-5 cursor-pointer bg-transparent border-none text-left text-base font-medium text-primary leading-[1.5] transition-colors hover:text-accent"
              data-faq-trigger
              aria-expanded="false"
            >
              <span>{faq.question}</span>
              <span class="shrink-0 text-accent text-lg transition-transform duration-300" data-faq-icon aria-hidden="true">+</span>
            </button>
            <div class="overflow-hidden transition-[max-height] duration-300 ease-[cubic-bezier(.4,0,.2,1)] max-h-0" data-faq-content>
              <div class="pb-5 pr-8 text-sm leading-[1.85] text-text/75">
                <Fragment set:html={renderLinks(faq.answer)} />
              </div>
            </div>
          </div>
        </RevealWrapper>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-faq-accordion]").forEach((accordion) => {
    const triggers = accordion.querySelectorAll<HTMLButtonElement>("[data-faq-trigger]");

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const item = trigger.closest("[data-faq-item]")!;
        const content = item.querySelector<HTMLElement>("[data-faq-content]")!;
        const icon = item.querySelector<HTMLElement>("[data-faq-icon]")!;
        const isOpen = trigger.getAttribute("aria-expanded") === "true";

        // Close all others
        accordion.querySelectorAll<HTMLElement>("[data-faq-item]").forEach((other) => {
          if (other === item) return;
          const otherContent = other.querySelector<HTMLElement>("[data-faq-content]")!;
          const otherIcon = other.querySelector<HTMLElement>("[data-faq-icon]")!;
          const otherTrigger = other.querySelector<HTMLButtonElement>("[data-faq-trigger]")!;
          otherContent.style.maxHeight = "0";
          otherIcon.style.transform = "rotate(0deg)";
          otherTrigger.setAttribute("aria-expanded", "false");
        });

        // Toggle current
        if (isOpen) {
          content.style.maxHeight = "0";
          icon.style.transform = "rotate(0deg)";
          trigger.setAttribute("aria-expanded", "false");
        } else {
          content.style.maxHeight = content.scrollHeight + "px";
          icon.style.transform = "rotate(45deg)";
          trigger.setAttribute("aria-expanded", "true");
        }
      });
    });
  });
</script>
