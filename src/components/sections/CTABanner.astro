<section class="relative bg-primary overflow-hidden text-center px-6 py-14 sm:px-10 md:px-16 lg:px-20 lg:py-[72px]">
  {/* Radial gradient overlay */}
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,#1A2D4755_0%,transparent_70%)]" />

  <div class="relative z-[1]">
    <h2 class="font-heading text-[26px] sm:text-[28px] lg:text-[30px] font-bold text-canvas mb-3.5">
      Begin a Conversation
    </h2>
    <p class="text-sm text-warm/60 max-w-[380px] mx-auto leading-[1.7] mb-8">
      We advise quietly, plan across decades, and measure success by stability, continuity, and outcomes over time.
    </p>
    {/* CTA wired to ContactModal in Phase 5 */}
    <a
      href="#contact"
      class="inline-block border border-accent text-canvas px-8 sm:px-11 py-3.5 text-[11px] tracking-[0.16em] uppercase font-body font-medium
             transition-all duration-300 ease-[cubic-bezier(.4,0,.2,1)] hover:bg-accent hover:text-primary hover:-translate-y-px cursor-pointer"
    >
      Schedule a Consultation
    </a>
  </div>
