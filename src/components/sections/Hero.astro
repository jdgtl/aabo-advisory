---
import LineReveal from "@/components/ui/LineReveal.astro";
import RevealWrapper from "@/components/ui/RevealWrapper.astro";
import { getHomepage } from "@/lib/content";
import { renderLinks } from "@/lib/markdown-links";

const hp = await getHomepage();
const hero = hp?.hero;
const headline = hero?.headline ?? "Real Estate Advisory\nfor Diplomatic Missions";
const subtext = hero?.subtext ?? "Strategic housing, acquisition, and long-term stewardship in global capitals.";
const description = hero?.description ?? "We advise diplomatic, foreign and private organizations on real estate decisions in New York, helping balance financial responsibility, operational needs, and long-term presence.";
const cta = hero?.cta ?? "Schedule a Consultation";

const headlineParts = headline.split("\n");
---

<section
  id="home"
  class="relative min-h-[85vh] flex flex-col justify-center bg-canvas overflow-hidden
         px-6 py-16 sm:px-10 md:px-16 lg:px-20 lg:py-20 lg:pb-[100px]"
>
  <div class="relative z-[1] max-w-[1100px] mx-auto w-full">
    <LineReveal width={48} class="mb-10" />

    <RevealWrapper>
      <h1 class="font-heading text-[32px] sm:text-[40px] md:text-[48px] lg:text-[54px] font-bold leading-[1.12] text-primary mb-7">
        {headlineParts.map((part, i) => (
          <>{i > 0 && <br />}{part}</>
        ))}
      </h1>
    </RevealWrapper>

    <RevealWrapper delay={0.1}>
      <p class="text-base sm:text-lg lg:text-[19px] leading-[1.65] text-warm max-w-[560px] mb-5">
        <Fragment set:html={renderLinks(subtext)} />
      </p>
    </RevealWrapper>

    <RevealWrapper delay={0.2}>
      <p class="text-sm lg:text-base leading-[1.75] text-text/70 max-w-[540px] mb-12">
        <Fragment set:html={renderLinks(description)} />
      </p>
    </RevealWrapper>

    <RevealWrapper delay={0.3}>
      <a
        href="#contact"
        class="inline-block border-[1.5px] border-primary text-primary px-8 sm:px-10 py-4 text-xs tracking-[0.16em] uppercase font-body font-medium
               transition-all duration-300 ease-[cubic-bezier(.4,0,.2,1)] hover:bg-primary hover:text-canvas hover:-translate-y-px cursor-pointer"
      >
        {cta}
      </a>
    </RevealWrapper>
  </div>
</section>
