---
import NavClient from "@/components/interactive/NavClient";

const sectionLinks = [
  { href: "/#home", id: "home", label: "Home" },
  { href: "/#approach", id: "approach", label: "Approach" },
  { href: "/#services", id: "services", label: "Advisory" },
  { href: "/insights", id: "insights", label: "Insights" },
  { href: "/#about", id: "about", label: "About" },
];
---

<div class="sticky top-0 z-40">
  <nav
    data-nav
    aria-label="Main navigation"
    class="flex items-center justify-between px-6 md:px-12 py-5 transition-all duration-400 ease-[cubic-bezier(.4,0,.2,1)] border-b border-transparent bg-canvas [&.nav-scrolled]:py-3 [&.nav-scrolled]:bg-canvas/95 [&.nav-scrolled]:backdrop-blur-xl [&.nav-scrolled]:border-mid"
  >
    {/* Logo */}
    <a href="/" class="flex items-baseline gap-2.5">
      <span class="font-heading text-[19px] font-bold text-primary tracking-[0.08em] transition-all duration-300">
        AABO
      </span>
      <span class="text-[10px] tracking-[0.15em] uppercase text-accent font-medium">
        Advisory
      </span>
    </a>

    {/* Desktop links */}
    <div class="hidden md:flex gap-7 items-center">
      {sectionLinks.map((link) => (
        <a
          href={link.href}
          data-nav-link={link.id}
          class="text-xs tracking-[0.06em] font-body text-text pb-0.5 border-b-[1.5px] border-transparent transition-all duration-300 hover:text-accent [&.nav-link-active]:text-accent [&.nav-link-active]:font-semibold [&.nav-link-active]:border-accent"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/calculator"
        class="text-xs tracking-[0.06em] font-body text-text pb-0.5 border-b-[1.5px] border-transparent transition-all duration-300 hover:text-accent"
      >
        Calculator
      </a>
      <a
        href="/#contact"
        class="bg-primary text-canvas px-5 py-2.5 text-[11px] tracking-[0.12em] uppercase font-body font-medium transition-all duration-300 hover:bg-secondary hover:-translate-y-px"
      >
        Schedule a Consultation
      </a>
    </div>

    {/* Mobile menu toggle (client island) */}
    <NavClient client:load />
  </nav>

  {/* Mobile drawer — outside <nav> to avoid stacking context trap */}
  <div data-nav-drawer class="fixed inset-x-0 top-[57px] bottom-0 bg-canvas flex-col items-center pt-12 gap-6 hidden md:!hidden z-50">
    {sectionLinks.map((link) => (
      <a
        href={link.href}
        data-nav-link={link.id}
        class="text-sm tracking-[0.06em] font-body text-text transition-colors hover:text-accent [&.nav-link-active]:text-accent [&.nav-link-active]:font-semibold"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/calculator"
      class="text-sm tracking-[0.06em] font-body text-text transition-colors hover:text-accent"
    >
      Calculator
    </a>
    <a
      href="/#contact"
      class="bg-primary text-canvas px-6 py-3 text-[11px] tracking-[0.12em] uppercase font-body font-medium mt-4"
    >
      Schedule a Consultation
    </a>
  </div>
</div>
