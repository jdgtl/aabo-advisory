---
import Article from "@/layouts/Article.astro";
import { reader, calcReadTime, formatDate } from "@/lib/content";
import Markdoc from "@markdoc/markdoc";

export async function getStaticPaths() {
  const slugs = await reader.collections.articles.list();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const article = await reader.collections.articles.read(slug!, {
  resolveLinkedFiles: true,
});

if (!article) {
  return Astro.redirect("/insights");
}

const allSlugs = await reader.collections.articles.list();
const allArticlesWithDates = (
  await Promise.all(
    allSlugs.map(async (s) => {
      const a = await reader.collections.articles.read(s);
      return a ? { slug: s, title: a.title, category: a.category, date: a.date, draft: a.draft } : null;
    })
  )
).filter(Boolean) as { slug: string; title: string; category: string; date: string; draft: boolean }[];

const otherArticles = allArticlesWithDates
  .filter((a) => a.slug !== slug && !a.draft)
  .sort((a, b) => (b.date ?? "").localeCompare(a.date ?? ""))
  .slice(0, 5)
  .map(({ slug: s, title: t, category: c }) => ({ slug: s, title: t, category: c }));

// Build doc ID from article year + sequential count within that year
const articleYear = article.date?.slice(0, 4) ?? "2025";
const sameYearArticles = allArticlesWithDates
  .filter((a) => a.date?.startsWith(articleYear))
  .sort((a, b) => a.date.localeCompare(b.date));
const yearIndex = sameYearArticles.findIndex((a) => a.slug === slug) + 1;
const docId = `AABO-${articleYear}-${String(yearIndex || 1).padStart(3, "0")}`;

const content = await article.body;
const rendered = Markdoc.renderers.html(Markdoc.transform(content.node));
const readTime = calcReadTime(rendered.replace(/<[^>]*>/g, ""));
const date = formatDate(article.date);
---

<Article
  title={article.title}
  category={article.category}
  excerpt={article.excerpt}
  keyTakeaway={article.keyTakeaway ?? ""}
  publicationUrl={article.publicationUrl ?? ""}
  publicationLabel={article.publicationLabel ?? ""}
  publicationLinkText={article.publicationLinkText ?? ""}
  date={date}
  readTime={readTime}
  docId={docId}
  slug={slug!}
  otherArticles={otherArticles}
>
  <Fragment set:html={rendered} />
</Article>
