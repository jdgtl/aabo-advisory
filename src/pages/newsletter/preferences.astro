---
export const prerender = false;

import "@/styles/global.css";
import PreferenceCenter from "@/components/interactive/PreferenceCenter";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Newsletter Preferences — Aabo Advisory</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-canvas text-text font-body antialiased">
  <header class="bg-primary px-6 md:px-12 py-5">
    <a href="/">
      <img src="/logo.svg" alt="Aabo Advisory" class="h-[36px] w-auto" />
    </a>
  </header>
  <main class="min-h-screen px-6 md:px-12 lg:px-20 pt-14 lg:pt-[60px] pb-16 lg:pb-20">
    <div class="max-w-[600px] mx-auto">
      <PreferenceCenter client:load />
    </div>
  </main>
  <footer class="bg-primary px-6 md:px-12 py-8 text-center">
    <p class="text-[11px] text-warm/25">&copy; {new Date().getFullYear()} Aabo Advisory</p>
  </footer>
</body>
</html>
