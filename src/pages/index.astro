---
import Base from "@/layouts/Base.astro";
import Nav from "@/components/sections/Nav.astro";
import Footer from "@/components/sections/Footer.astro";
import Label from "@/components/ui/Label.astro";
import DivLine from "@/components/ui/DivLine.astro";
import LineReveal from "@/components/ui/LineReveal.astro";
import Button from "@/components/ui/Button";
import Card from "@/components/ui/Card";
import RevealWrapper from "@/components/ui/RevealWrapper";
---

<Base>
  <Nav />

  <main>
    {/* Hero */}
    <section id="home" class="flex flex-col items-center justify-center min-h-[80vh] px-6 text-center">
      <RevealWrapper client:visible>
        <Label text="Diplomatic Real Estate Advisory" />
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-primary mb-4 max-w-2xl">
          AABO Advisory
        </h1>
        <p class="text-base md:text-lg text-secondary mb-8 max-w-xl mx-auto">
          We advise quietly, plan across decades, and measure success by
          stability, continuity, and outcomes over time.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <Button variant="primary">Schedule a Consultation</Button>
          <Button variant="outline">Our Approach</Button>
          <Button variant="ghost">Learn More</Button>
        </div>
      </RevealWrapper>
      <LineReveal width={64} class="mt-12" />
    </section>

    <DivLine />

    {/* Approach — demonstrates Card + RevealWrapper */}
    <section id="approach" class="py-20 px-6 md:px-12 lg:px-20">
      <div class="max-w-[1100px] mx-auto">
        <RevealWrapper client:visible>
          <Label text="Our Approach" />
          <h2 class="font-heading text-3xl md:text-4xl text-primary mb-10">
            Three Pillars
          </h2>
        </RevealWrapper>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <RevealWrapper client:visible delay={0}>
            <Card className="bg-light p-8 rounded">
              <h3 class="font-heading text-xl text-primary mb-3">Long-Term Lens</h3>
              <p class="text-sm text-text/70 leading-relaxed">
                Real estate decisions that span diplomatic tenures and generational timelines.
              </p>
            </Card>
          </RevealWrapper>
          <RevealWrapper client:visible delay={0.1}>
            <Card className="bg-light p-8 rounded">
              <h3 class="font-heading text-xl text-primary mb-3">Dual Audience</h3>
              <p class="text-sm text-text/70 leading-relaxed">
                Advisory calibrated for both sovereign missions and private diplomatic families.
              </p>
            </Card>
          </RevealWrapper>
          <RevealWrapper client:visible delay={0.2}>
            <Card className="bg-light p-8 rounded">
              <h3 class="font-heading text-xl text-primary mb-3">Discretion &amp; Precision</h3>
              <p class="text-sm text-text/70 leading-relaxed">
                Every engagement handled with the confidentiality that diplomatic service demands.
              </p>
            </Card>
          </RevealWrapper>
        </div>
      </div>
    </section>

    {/* Placeholder sections for nav section tracking */}
    <section id="services" class="py-20 px-6">
      <div class="max-w-[1100px] mx-auto">
        <Label text="Advisory Services" />
        <h2 class="font-heading text-3xl text-primary">Advisory</h2>
      </div>
    </section>
    <section id="insights" class="py-20 px-6">
      <div class="max-w-[1100px] mx-auto">
        <Label text="Insights" />
        <h2 class="font-heading text-3xl text-primary">Insights</h2>
      </div>
    </section>
    <section id="about" class="py-20 px-6">
      <div class="max-w-[1100px] mx-auto">
        <Label text="About" />
        <h2 class="font-heading text-3xl text-primary">About</h2>
      </div>
    </section>
  </main>

  <Footer />
</Base>
